{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "LPG",
  "scopeName": "source.lpg",
  "patterns": [
    { "include": "#comment" },
    { "include": "#action-block" },
    { "include": "#section-keyword" },
    { "include": "#option-assignment" },
    { "include": "#macro" },
    { "include": "#string" },
    { "include": "#rule-definition" },
    { "include": "#produces" },
    { "include": "#ebnf-operator" },
    { "include": "#or-marker" },
    { "include": "#terminal-name" },
    { "include": "#nonterminal-name" }
  ],
  "repository": {
    "comment": {
      "name": "comment.line.double-dash.lpg",
      "match": "--.*$"
    },
    "action-block": {
      "name": "meta.embedded.block.action.lpg",
      "begin": "/\\.",
      "end": "\\./",
      "beginCaptures": {
        "0": { "name": "punctuation.definition.action.begin.lpg" }
      },
      "endCaptures": {
        "0": { "name": "punctuation.definition.action.end.lpg" }
      },
      "patterns": [
        { "name": "comment.line.double-dash.lpg", "match": "--.*$" },
        { "name": "string.quoted.double.lpg", "begin": "\"", "end": "\"", "patterns": [{ "match": "\\\\." }] },
        { "name": "string.quoted.single.lpg", "begin": "'", "end": "'", "patterns": [{ "match": "\\\\." }] }
      ]
    },
    "section-keyword": {
      "name": "keyword.control.section.lpg",
      "match": "(?i)%(Options|Alias|Ast|Define|Eof|Eol|Error|Export|Globals|Headers|Identifier|Import|Include|Keywords|Names|Notice|Rules|SoftKeywords|Start|Terminals|Trailers|Types|Recover|End|DroppedSymbols|DroppedRules|DisjointPredecessorSets)\\b"
    },
    "option-assignment": {
      "match": "(?i)\\b([A-Za-z_][A-Za-z0-9_]*)\\s*(=)",
      "captures": {
        "1": { "name": "entity.name.tag.option.lpg" },
        "2": { "name": "keyword.operator.assignment.lpg" }
      }
    },
    "macro": {
      "name": "variable.other.macro.lpg",
      "match": "\\$[A-Za-z_][A-Za-z0-9_]*"
    },
    "string": {
      "patterns": [
        {
          "name": "string.quoted.single.lpg",
          "begin": "'",
          "end": "'",
          "patterns": [
            { "name": "constant.character.escape.lpg", "match": "''" }
          ]
        },
        {
          "name": "string.quoted.double.lpg",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            { "name": "constant.character.escape.lpg", "match": "\"\"" }
          ]
        },
        {
          "name": "string.quoted.other.bracket.lpg",
          "begin": "<",
          "end": ">",
          "patterns": [
            { "name": "constant.character.escape.lpg", "match": "\\\\." }
          ]
        }
      ]
    },
    "rule-definition": {
      "match": "(?:^|\\G)\\s*([A-Za-z_][A-Za-z0-9_]*)\\s*(::=\\??|->\\??)",
      "captures": {
        "1": { "name": "entity.name.function.lpg" },
        "2": { "name": "keyword.operator.produces.lpg" }
      }
    },
    "produces": {
      "name": "keyword.operator.produces.lpg",
      "match": "(::=\\??|->\\??)"
    },
    "ebnf-operator": {
      "name": "keyword.operator.ebnf.lpg",
      "match": "[?*+(){}\\[\\]]"
    },
    "or-marker": {
      "name": "keyword.operator.or.lpg",
      "match": "\\|"
    },
    "terminal-name": {
      "name": "constant.language.lpg",
      "match": "\\b[A-Z][A-Z0-9_]*\\b"
    },
    "nonterminal-name": {
      "name": "entity.name.type.lpg",
      "match": "\\b[A-Za-z_][A-Za-z0-9_]*\\b"
    }
  }
}
